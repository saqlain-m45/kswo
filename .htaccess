RewriteEngine On

# Automatically detect the base directory
RewriteRule ^ - [E=REWRITEBASE:/]
<If "%{REQUEST_URI} =~ m#^/KSWOP/#">
    RewriteBase /KSWOP/
</If>

# Route /admin to admin/login.php (Internal rewrite to avoid path loss)
RewriteRule ^admin/?$ admin/login.php [L]
RewriteRule ^superadmin/?$ superadmin/login.php [L]

# Redirect legacy root login and register to join.php
RewriteRule ^login\.php$ join.php?tab=login [R=301,L]
RewriteRule ^register\.php$ join.php?tab=register [R=301,L]

# Prevent directory listing
Options -Indexes
